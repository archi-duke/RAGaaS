# Copy this file to .env and fill in your values
# 인프라(MongoDB/Milvus/Fuseki/Neo4j/Redis)는 shared-infra 스택 사용
# (개발 환경: D:\Works\shared-infra — 앱보다 먼저 기동할 것)

# OpenAI API Key (required)
OPENAI_API_KEY=your_openai_api_key_here

# Shared MongoDB - ragaas_app 계정 비밀번호
# shared-infra/.env 의 RAGAAS_MONGO_PASSWORD 와 동일하게 설정
RAGAAS_MONGO_PASSWORD=ragaas-dev-pass

# Shared Neo4j 비밀번호 (shared-infra/.env 의 NEO4J_PASSWORD 와 동일하게)
NEO4J_PASSWORD=password

# Encryption key for custom provider API keys
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Frontend build (optional)
TELERIK_LICENSE=

# ──────────────────────────────────────────────────────────────────────
# 플랫폼 합류 (Platform-App 셸) — docs/platform-contract/05 §6
# ──────────────────────────────────────────────────────────────────────
# SSO 모드: "true" 면 백엔드가 Bearer 토큰을 introspect 로 검증 (미인증 401).
# false(기본)면 dev 폴백(X-User-Id → X-Dev-User → DEV_USER).
USE_SSO=false
# introspect 베이스 URL (SSO 모드 필수) — 예: https://sso.example.com
SSO_INTROSPECT_URL=
# 사내 사설 인증서 대비 TLS 검증 우회 토글
SSO_INSECURE_TLS=false
# 서비스간 공유비밀 (backend↔ingest, 플랫폼↔RAGaaS). 미설정 시 서비스토큰 경로 전면 거부.
# 플랫폼(deploy/.env)의 SERVICE_TOKEN 과 동일 값으로 배포할 것.
SERVICE_TOKEN=
# dev 폴백 신원
DEV_USER=dev

# 프론트 런타임 env (컨테이너 기동 시 env.js 로 직렬화 — 재빌드 불필요)
# 셸(게이트웨이) 배포 예: REACT_APP_RAGAAS_API=http://gateway:8080/ragaas-api/api/v2
# 비우면 standalone 폴백(/api/v2/, /ingest-api/ — 프론트 nginx 프록시)
REACT_APP_RAGAAS_API=
REACT_APP_RAGAAS_INGEST_API=
REACT_APP_SSO_URL=

# ──────────────────────────────────────────────────────────────────────
# 사내망 LLM 게이트웨이 인증 시크릿 (선택 — 사내 배포 시)
# ──────────────────────────────────────────────────────────────────────
# RAGaaS 는 프록시 없이 프로바이더를 직접 호출한다. 사내 게이트웨이를
# CustomProvider 로 등록할 때, 인증/부가정보 헤더에 아래 값을 ${VAR} 로 참조하면
# 시크릿을 DB 평문에 저장하지 않고 환경변수로 주입할 수 있다.
#
#   예) CustomProvider.extra_headers = {
#         "X-Dep-Ticket":     "${LLM_DEP_TICKET}",
#         "Send-System-Name": "ai4se",
#         "User-Id":          "${LLM_USER_ID}",
#         "User-Type":        "AD_ID",
#         "Chat-Id":          "00000000-0000-0000-0000-000000000000"
#       }
#   base_url = http://apigw.samsungds.net:8000/gpt-oss/1/gpt-oss-120b/v1
#   model    = openai/gpt-oss-120b
#
# 임베딩 게이트웨이는 embedding_request_format="minimal" + extra_headers 로 등록.
EMBEDDING_DEP_TICKET=
LLM_DEP_TICKET=
LLM_USER_ID=
