# ======================================================
# RAGaaS Docker Deployment Environment Variables
# Usage: cp .env.docker .env  (then fill in actual values)
# ======================================================

# Database Configuration (Docker service names)
MONGO_URI=mongodb://root:example@mongo:27017
MONGO_DB=ragaas

# Infrastructure (Docker service names - auto-configured in docker-compose)
MILVUS_HOST=standalone
MILVUS_PORT=19530
FUSEKI_URL=http://fuseki:3030
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
REDIS_URL=redis://redis:6379/0

# Inter-service URLs (Docker service names)
MAIN_BACKEND_URL=http://backend:8000
INGEST_SERVICE_URL=http://ingest-service:8001
CALLBACK_BASE_URL=http://backend:8000
PROXY_SERVICE_URL=http://samsung-ds-proxy:8010

# Storage
SHARED_STORAGE_PATH=/data/uploads
DOCKER_VOLUME_DIRECTORY=.

# API Key Encryption Key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Telerik/Kendo UI License (for frontend build)
TELERIK_LICENSE=

# ──────────────────────────────────────────────────────
# Samsung DS API Gateway Proxy (optional)
# ──────────────────────────────────────────────────────
EMBEDDING_DEP_TICKET=
LLM_DEP_TICKET=
LLM_USER_ID=
