# --- Docker Hub Config ---
DOCKER_HUB_USER=dukekimm

# --- API Keys ---
OPENAI_API_KEY=your_openai_api_key_here

# --- Infrastructure Hosts (Do not change for Docker Compose) ---
MILVUS_HOST=milvus-standalone
ETCD_ENDPOINTS=etcd:2379
MINIO_ADDRESS=minio:9000
FUSEKI_HOST=fuseki
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
MONGODB_URL=mongodb://mongo:27017
REDIS_HOST=redis

# --- Service Ports ---
BACKEND_PORT=8000
INGEST_PORT=8001
FRONTEND_PORT=80

# --- Directory Config ---
DOCKER_VOLUME_DIRECTORY=./data
